# BSVibe app — PRODUCTION environment template.
#
# Copy to deploy/.env.prod and fill in real values. .env.prod is gitignored
# (matched by `.env.*.local`? NO — add it to .gitignore or keep it OUT of git
# manually; it holds secrets). NEVER commit the filled file.
#
# Used by: `docker compose -f deploy/compose.yaml -f deploy/compose.prod.yaml \
#   --env-file deploy/.env.prod up -d`
# Most vars use the BSVIBE_ prefix (backend/config.py, class Settings). The
# USER_JWT_* session-verification vars are the exception — they are UNPREFIXED
# and read by backend/shared/authz (class Settings) — see that section below.

# ----------------------------------------------------------------------------
# Database — TWO-ROLE Postgres (B2b). The compose.prod stack runs its own
# Postgres (pgvector/pg16). BSVIBE_DB_PASSWORD seeds the container's OWNER role
# `bsvibe` (superuser). The host is the compose service name `postgres`
# (internal network only — the prod override does NOT publish 5432).
#
# Postgres RLS is only a REAL layer-3 tenant-isolation backstop when the app
# connects as a NON-superuser role. So there are TWO DSNs + TWO passwords:
#
#   OWNER  (bsvibe)     — runs migrations, owns objects, manages roles/policies.
#                         Superuser / BYPASSRLS: RLS does NOT govern it.
#   RUNTIME (bsvibe_app) — the app + worker connect as this. NOSUPERUSER
#                         NOBYPASSRLS: RLS + FORCE actually govern it. The
#                         `runtime_role` migration CREATEs it and sets its
#                         password from BSVIBE_APP_DB_PASSWORD (below).
#
# On the FIRST deploy that includes the runtime_role migration, the backend
# entrypoint's `alembic upgrade head` (running as the OWNER via
# BSVIBE_MIGRATION_DATABASE_URL) provisions bsvibe_app + all grants. See
# docs/e2e/two-role-rls-checklist.md for the cutover + rollback runbook.
# ----------------------------------------------------------------------------
# Owner role password (seeds the postgres container's `bsvibe` superuser).
BSVIBE_DB_PASSWORD=change-me-strong-db-password
# Runtime role password — the runtime_role migration assigns this to bsvibe_app.
# MUST match the userinfo in BSVIBE_DATABASE_URL below. Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BSVIBE_APP_DB_PASSWORD=change-me-strong-app-role-password
# RUNTIME DSN — the app + worker connect as bsvibe_app (RLS-governed).
BSVIBE_DATABASE_URL=postgresql+asyncpg://bsvibe_app:change-me-strong-app-role-password@postgres:5432/bsvibe
# OWNER DSN — alembic runs as bsvibe (DDL + CREATE ROLE). Only the backend
# service (which migrates on boot) reads it.
BSVIBE_MIGRATION_DATABASE_URL=postgresql+asyncpg://bsvibe:change-me-strong-db-password@postgres:5432/bsvibe

# Redis — internal compose service `redis`; not published to the host in prod.
# Defense-in-depth: Redis runs with `--requirepass`. Set the password here (the
# SINGLE source of truth) — redis-server's --requirepass, the healthcheck, and
# the app's BSVIBE_REDIS_URL default all derive from it. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BSVIBE_REDIS_PASSWORD=change-me-strong-redis-password
# Leave BSVIBE_REDIS_URL UNSET — the compose default already embeds
# BSVIBE_REDIS_PASSWORD (redis://:<pw>@redis:6379/0). Only set it explicitly if
# you point at an external Redis, and then it MUST carry the password inline.
# BSVIBE_REDIS_URL=redis://:change-me-strong-redis-password@redis:6379/0

# CORS allow-list for the browser PWA calling api.bsvibe.dev cross-origin
# (Bearer-header auth, not cookies). Comma-separated origins — set the
# deployed PWA origin(s); no wildcard.
BSVIBE_CORS_ALLOWED_ORIGINS=https://app.bsvibe.dev

# Environment + worker trigger mode.
BSVIBE_ENVIRONMENT=prod
# db_polling = the tested default (each worker polls its source table).
# redis_streams = opt-in XADD wake-up + XREADGROUP consumer (DB stays SoT).
BSVIBE_WORKER_MODE=db_polling

# Git SHA — pass GIT_SHA at build time (`--build-arg GIT_SHA=$(git rev-parse --short HEAD)`);
# this env var is mostly informational at runtime (the image bakes it in).
BSVIBE_GIT_SHA=

# ----------------------------------------------------------------------------
# Credential encryption key — REQUIRED in prod.
# AES-256-GCM 32-byte key, URL-SAFE base64 (backend/router/accounts/crypto.py does
# base64.urlsafe_b64decode and asserts exactly 32 decoded bytes). Without it,
# storing a ModelAccount / connector credential raises at runtime.
#
# Generate (CORRECT — url-safe alphabet, decodes to 32 bytes):
#   python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#
# Do NOT use `openssl rand -base64 32` — that emits the STANDARD base64
# alphabet (may contain + or /), which urlsafe_b64decode rejects.
# ----------------------------------------------------------------------------
BSVIBE_GATEWAY_KMS_KEY_B64=

# ----------------------------------------------------------------------------
# Connector OAuth — GitHub App: NO env vars (DB is the single source of truth).
# Set the App up in-app: PWA Settings → Connectors → "Set up GitHub App" (or the
# MCP tool bsvibe_connectors_github_app_setup_url) → approve "Create GitHub App"
# on GitHub once. The manifest flow stores client_id/secret/app_id/private-key
# encrypted in connector_oauth_app_credentials and loads them at startup.
# (Manual alternative: create the App at github.com → Settings → Developer
# settings → GitHub Apps, with callback
# <BSVIBE_OAUTH_ISSUER>/api/v1/connectors/oauth/github/callback. No
# BSVIBE_GITHUB_APP_* runtime var exists.)
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Supabase IdP (GoTrue) — the backend calls Supabase directly for login /
# OAuth code exchange / refresh / logout. Both required for real auth in prod.
# ----------------------------------------------------------------------------
BSVIBE_SUPABASE_URL=https://your-project.supabase.co
# Supabase **publishable** key (sb_publishable_...), used as the GoTrue apikey.
BSVIBE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-supabase-publishable-key
# Region stamped onto workspaces created at signup.
BSVIBE_DEFAULT_WORKSPACE_REGION=us-1

# ----------------------------------------------------------------------------
# Session-JWT verification — REQUIRED in prod. NOTE: these are NOT BSVIBE_-
# prefixed; they are read by backend/shared/authz (class Settings, no prefix).
# The backend authenticates LOGIN against Supabase GoTrue (above), then must
# VERIFY the returned ES256 session JWT on every /api/v1/* request. Verify it
# via the Supabase project's JWKS (asymmetric, kid-rotating). Without these the
# verifier defaults to HS256 + a missing secret and all authenticated calls 401
# with "user_jwt_secret not configured".
#
#   USER_JWT_JWKS_URL = <BSVIBE_SUPABASE_URL>/auth/v1/.well-known/jwks.json
#   USER_JWT_ISSUER   = <BSVIBE_SUPABASE_URL>/auth/v1
#   USER_JWT_AUDIENCE = authenticated   (Supabase stamps aud="authenticated")
#   USER_JWT_ALGORITHM = ES256          (current Supabase signing algorithm)
# ----------------------------------------------------------------------------
USER_JWT_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
USER_JWT_ISSUER=https://your-project.supabase.co/auth/v1
USER_JWT_AUDIENCE=authenticated
USER_JWT_ALGORITHM=ES256

# ----------------------------------------------------------------------------
# Sandbox (work/verification execution) — leave disabled until the LLM phase.
# When enabled, the worker spawns a per-project bsvibe-sandbox container via the
# Docker host and runs the verifier's declared `command` checks (pytest/ruff/uv)
# inside it. Requires:
#   - the `sandbox` compose profile up (the docker:dind sidecar) — see README §5
#   - the sandbox image built + LOADED INTO the dind daemon
#     (tools/build-sandbox-image.sh; a plain host build is invisible to the dind)
#   - DOCKER_HOST pointing at the dind sidecar (tcp://sandbox-dind:2375)
#   - SANDBOX_USER=0:0 so the sandbox can write the worker's root-owned worktree
#
# NETWORK ISOLATION (automatic, no env): the sandbox-dind image is hardened
# (deploy/Dockerfile.sandbox-dind + sandbox-dind-firewall.sh) so nested
# bsvibe-sbx-* containers CANNOT reach the daemon's :2375 control socket,
# postgres, redis, or the backend — only the public internet (PyPI/npm). The
# :2375 socket itself lives on a dedicated `sandboxnet` reachable only by
# backend/worker. Verify against a live host with
# docs/e2e/sandbox-network-isolation-checklist.md.
# ----------------------------------------------------------------------------
BSVIBE_SANDBOX_ENABLED=true
BSVIBE_DOCKER_HOST=tcp://sandbox-dind:2375
BSVIBE_SANDBOX_USER=0:0
BSVIBE_SANDBOX_IMAGE=bsvibe-sandbox:latest
BSVIBE_SANDBOX_IDLE_REAP_SECONDS=1800
BSVIBE_SANDBOX_MAX_CONCURRENT=2

# ----------------------------------------------------------------------------
# Filesystem roots — vault (knowledge), skills, and per-run workspaces.
# These live on the `appdata` volume mounted at /app/var in the prod override.
# Keep them under /app/var so they persist across container recreation.
# ----------------------------------------------------------------------------
BSVIBE_KNOWLEDGE_VAULT_ROOT=/app/var/vault
BSVIBE_KNOWLEDGE_DEFAULT_REGION=us-1
# Knowledge semantic-search embedding (G6) — the pgvector index DERIVED from the
# Markdown notes. Set the model to turn on semantic search; empty disables it.
# Containers reach a host Ollama via host.docker.internal.
BSVIBE_KNOWLEDGE_EMBEDDING_MODEL=ollama/bge-m3
BSVIBE_KNOWLEDGE_EMBEDDING_API_BASE=http://host.docker.internal:11434
BSVIBE_SKILLS_ROOT=/app/var/skills
BSVIBE_RUN_WORKSPACE_ROOT=/app/var/runs

# ----------------------------------------------------------------------------
# Audit relay sink — optional. Empty selects the no-sink LoggingRelay
# (drain + ack, no remote delivery). Set to an HTTPS endpoint to forward.
# ----------------------------------------------------------------------------
BSVIBE_AUDIT_RELAY_URL=

# ----------------------------------------------------------------------------
# Gateway classifier thresholds + execution budgets — defaults are fine for
# most deployments; override only when tuning local-LLM vs frontier routing.
# (See backend/config.py for the full list + defaults.)
# ----------------------------------------------------------------------------
# BSVIBE_GATEWAY_LOCAL_SCORE_MAX=40
# BSVIBE_GATEWAY_CLOUD_SCORE_MIN=60
# BSVIBE_EXECUTION_WORK_ROUND_BUDGET=48
