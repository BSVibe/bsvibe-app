# BSVibe app — environment variables
# Copy to .env and fill in. .env is gitignored.
# All vars use the BSVIBE_ prefix; see backend/config.py.

# Postgres — host:port matches the slot's PG_PORT (devcontainer wt-1: 15442)
BSVIBE_DATABASE_URL=postgresql+asyncpg://bsvibe:bsvibe@localhost:5442/bsvibe

# Redis — host:port matches the slot's REDIS_PORT (devcontainer wt-1: 16387)
BSVIBE_REDIS_URL=redis://localhost:6387/0

# Environment: dev | staging | prod
BSVIBE_ENVIRONMENT=dev

# Worker trigger mode: db_polling (default) | redis_streams
# db_polling: each worker periodically polls its source table (the tested default).
# redis_streams: producers ALSO XADD a wake-up notification + the worker daemon
#   consumes via XREADGROUP/XACK (opt-in scale/latency; DB stays source of truth).
BSVIBE_WORKER_MODE=db_polling

# Git SHA — injected by Docker build; "dev" outside containers
BSVIBE_GIT_SHA=dev

# CORS allow-list for the browser PWA calling the backend cross-origin
# (Bearer-header auth, not cookies). Comma-separated origins; default is the
# local PWA dev port. In prod set the deployed PWA origin(s).
BSVIBE_CORS_ALLOWED_ORIGINS=http://localhost:3700

# Connector OAuth — GitHub App (design Lift 1). bsvibe acts as an OAuth client
# of GitHub: client_id/secret drive "Connect with GitHub" (user-to-server
# OAuth); app_id + the PEM private key additionally enable installation tokens.
# All empty → no github provider registered; the connector falls back to the
# legacy signing-secret/PAT path. NEVER commit real values.
#
# OPTIONAL (Lift 1.5): you can skip these entirely and instead click
# "Set up GitHub App" in the PWA — the manifest flow creates the App on GitHub
# and stores the credentials in the DB (encrypted). DB creds override these.
BSVIBE_GITHUB_APP_CLIENT_ID=
BSVIBE_GITHUB_APP_CLIENT_SECRET=
BSVIBE_GITHUB_APP_ID=
BSVIBE_GITHUB_APP_PRIVATE_KEY_PEM=

# Other OAuth connectors (Lift 2-5) — one App per provider; the connector
# offers "Connect with X" only when both id + secret are set. slack: bot OAuth
# v2. notion / discord: Basic-auth token exchange. sentry: install→grant
# integration (its connect-flow wiring is a follow-up — see the design doc).
BSVIBE_SLACK_CLIENT_ID=
BSVIBE_SLACK_CLIENT_SECRET=
BSVIBE_NOTION_CLIENT_ID=
BSVIBE_NOTION_CLIENT_SECRET=
BSVIBE_DISCORD_CLIENT_ID=
BSVIBE_DISCORD_CLIENT_SECRET=
BSVIBE_SENTRY_CLIENT_ID=
BSVIBE_SENTRY_CLIENT_SECRET=
